# Testnet faucet (Ed25519 private key, 64 hex chars)
SHIVA_FAUCET_PRIVATE_KEY=

# Optional API key for POST /api/v1/tx and /rpc
SHIVA_API_KEY=

# CORS origins (comma-separated) for browser wallet
SHIVA_CORS_ORIGINS=http://localhost:8545,http://127.0.0.1:9338,https://your-domain.com

# Bridge (Docker / systemd — optional overrides)
SHIVA_NODE_URL=http://127.0.0.1:8545
SHIVA_BRIDGE_LISTEN=:9338
SHIVA_WALLET_PATH=
SHIVA_PROJECT_ROOT=

# Shiva AI (OpenAI-compatible: OpenAI, Azure, local LM Studio, etc.)
SHIVA_AI_ENABLED=true
SHIVA_AI_API_KEY=
SHIVA_AI_BASE_URL=https://api.openai.com/v1
SHIVA_AI_MODEL=gpt-4o-mini
