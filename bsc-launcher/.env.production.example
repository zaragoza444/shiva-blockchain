# Production — copy to bsc-launcher/.env before deploy

BSC_LAUNCHER_ENV=production
BSC_LAUNCHER_LISTEN=:9340
BSC_LAUNCHER_DATA_DIR=/data

# Required: protect deploy/register endpoints
BSC_LAUNCHER_API_KEY=change-me-to-a-long-random-secret

# Your public site URL(s), comma-separated (no * in production)
# For local prod test add: http://127.0.0.1:9340,http://localhost:9340
BSC_LAUNCHER_CORS_ORIGINS=https://tokens.yourdomain.com

# BSC RPC — use a dedicated provider in production (NodeReal, Ankr, QuickNode)
BSC_RPC_URL=https://bsc-dataseed.binance.org

# Optional: platform wallet deploy (fund with BNB)
BSC_DEPLOYER_PRIVATE_KEY=

# Etherscan API V2 key — holders/transfers on dashboard
BSCSCAN_API_KEY=

# Rate limit for backend deploy (per IP per minute)
BSC_LAUNCHER_RATE_LIMIT=10
