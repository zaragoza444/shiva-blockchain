# Copy remotes.env.example → remotes.env and set your Gitea git URL.
# Used by scripts/publish-production.ps1 and scripts/push-now.ps1

GITHUB_USER=zaragoza444
REPO_NAME=onex-blockchain

# Example: https://gitea.com/zaragoza444/onex-blockchain.git
GITEA_URL=

# Public bridge (Render) — also set GitHub variable ONEX_BRIDGE_PUBLIC_URL
ONEX_BRIDGE_PUBLIC_URL=
